---
import '../styles/global.css';

const {
  lang = 'es',
  title = 'ODS para Informática',
  description = '',
  assetBase = './',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${assetBase}favicon.svg`} />
    <link rel="icon" href={`${assetBase}favicon.ico`} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
